  "keywords": [
    "scaffold"
  ],
  "author": "im@gman.io",
  "license": "MIT",
  "husky": {
    "hooks": {
      "pre-commit": "npm run type-check && lint-staged"
    }
  },
  "lint-staged": {
    "*.tsx": [
      "eslint --fix",
      "prettier"
    ],
    "*.ts": [
      "eslint --fix",
      "prettier"
    ]
  }
}
